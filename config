# wklej do ~/.config/i3/config

set $mod Mod4
font pango:JetBrains Mono 13

# brak obramowań okien
# brak ramek
default_border none
default_floating_border none

for_window [class=".*"] border pixel 0

# terminal
bindsym $mod+Return exec kitty

# launcher
bindsym $mod+d exec rofi -show drun

# zamykanie okna
bindsym $mod+Shift+q kill

# restart i3
bindsym $mod+Shift+r restart

# wyjście
bindsym $mod+Shift+e exit

# focus
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# podział okien
bindsym $mod+v split v
bindsym $mod+b split h

# fullscreen
bindsym $mod+f fullscreen toggle

# workspace
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"

bindsym $mod+1 workspace $ws1
bindsym $mod+2 workspace $ws2
bindsym $mod+3 workspace $ws3
bindsym $mod+4 workspace $ws4
bindsym $mod+5 workspace $ws5
bindsym $mod+6 workspace $ws6

# uruchamianie
exec --no-startup-id feh --bg-scale /home/xfxfc/Downloads/Pobrane/best.jpg
exec --no-startup-id picom

# czułość myszy
exec --no-startup-id xinput set-prop 9 "libinput Accel Speed" -0.7

# rozdzielczość i częstotliwość
exec --no-startup-id xrandr --output HDMI-1 --mode 1920x1080 --rate 100.00

# === TOP BAR ===
bar {
    status_command i3status
    position top
    font pango:JetBrains mono 10
    colors {
        background #111111
        statusline #eeeeee
        separator  #666666
        focused_workspace  #444444 #444444 #ffffff
        active_workspace   #222222 #222222 #aaaaaa
        inactive_workspace #111111 #111111 #888888
        urgent_workspace   #900000 #900000 #ffffff
    }
}
[xfxfc@arch-btw ~]
